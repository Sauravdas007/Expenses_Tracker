// Prisma schema — expense tracker
// Swap `provider` + DATABASE_URL to postgresql/mysql for production scale.
datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// An Expense. `amountMinor` stores money as an integer in minor units (paise)
// to avoid floating-point errors. E.g. ₹123.45 -> 12345.
model Expense {
  id           String   @id @default(cuid())
  amountMinor  Int
  currency     String   @default("INR")
  category     String
  description  String
  // stored as ISO date (YYYY-MM-DD) in a string for SQLite-friendliness
  date         String
  createdAt    DateTime @default(now())

  @@index([category])
  @@index([date])
}

// Stores server-side result of a POST keyed by Idempotency-Key, so retries
// return the same Expense instead of creating duplicates.
model IdempotencyRecord {
  key         String   @id
  expenseId   String   @unique
  createdAt   DateTime @default(now())
}
