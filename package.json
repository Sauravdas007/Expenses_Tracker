{
  "name": "expense-tracker",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000 -H 0.0.0.0",
    "start": "next dev -p 3000 -H 0.0.0.0",
    "build": "prisma generate && prisma db push && next build",
    "start:prod": "next start -p 3000 -H 0.0.0.0",
    "lint": "next lint",
    "test": "vitest run",
    "postinstall": "prisma generate && prisma db push --skip-generate || true"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "clsx": "2.1.1",
    "lucide-react": "0.454.0",
    "next": "14.2.15",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "2.5.4",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.16.11",
    "@types/react": "18.3.11",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.20",
    "eslint": "8.57.1",
    "eslint-config-next": "14.2.15",
    "postcss": "8.4.47",
    "prisma": "5.22.0",
    "tailwindcss": "3.4.13",
    "typescript": "5.6.3",
    "vitest": "2.1.3"
  }
}
